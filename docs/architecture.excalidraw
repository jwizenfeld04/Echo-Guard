      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 1005, "version": 1, "versionNonce": 1005,
      "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false,
      "text": "Tier 1: AST Hash Matching\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nType-1 / Type-2 Clones\n\n\u2022 Normalize AST identifiers\n\u2022 SHA-256 fingerprint (16-char)\n\u2022 O(1) hash-map lookup\n\n\u2713 100% recall on Type-1/2\n\u2713 Zero false positives",
      "fontSize": 13, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle",
      "containerId": "tier1_r",
      "originalText": "Tier 1: AST Hash Matching\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nType-1 / Type-2 Clones\n\n\u2022 Normalize AST identifiers\n\u2022 SHA-256 fingerprint (16-char)\n\u2022 O(1) hash-map lookup\n\n\u2713 100% recall on Type-1/2\n\u2713 Zero false positives",
      "lineHeight": 1.25
    },
